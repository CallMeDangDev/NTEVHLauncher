<Window x:Class="NTEVHLauncher.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        SizeToContent="Height"
        Width="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="GoldBrush"    Color="#7B5CE7"/>
        <SolidColorBrush x:Key="GoldWarmBrush" Color="#9B7FFA"/>
    </Window.Resources>

    <Border Background="#0E0B1C"
            BorderBrush="#7B5CE7"
            BorderThickness="1"
            CornerRadius="10"
            Padding="28,24,28,22">
        
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" ShadowDepth="0" Opacity="0.7"/>
        </Border.Effect>

        <StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Viewbox Width="20" Height="20" Margin="0,1,10,0">
                    <Canvas Width="24" Height="24">
                        <Path Fill="#9B7FFA"
                              Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10
                                    10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/>
                    </Canvas>
                </Viewbox>
                <TextBlock x:Name="TitleText"
                           Text="Xác nhận"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Rectangle Height="1" Fill="#18143A" Margin="0,0,0,16"/>

            <TextBlock x:Name="MessageText"
                       Text=""
                       FontSize="13"
                       Foreground="#C4B5FD"
                       TextWrapping="Wrap"
                       LineHeight="20"
                       Margin="0,0,0,24"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancel"
                        Content="Huỷ"
                        Width="88" Height="34"
                        Margin="0,0,10,0"
                        FontSize="12" FontFamily="Segoe UI"
                        Foreground="#9890C8"
                        Background="#100C22"
                        BorderBrush="#2A2060"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="BtnCancel_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#18143A"/>
                                                <Setter Property="BorderBrush" Value="#4535A0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="BtnOk"
                        Content="Xác nhận"
                        Width="88" Height="34"
                        FontSize="12" FontFamily="Segoe UI"
                        Foreground="#0E0B1C"
                        Background="#7B5CE7"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnOk_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#9B7FFA"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
